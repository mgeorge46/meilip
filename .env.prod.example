# Meili Property — production .env template.
# Copy to .env on the prod host and fill in.

# --- Django ---------------------------------------------------------------
DJANGO_ENV=prod
SECRET_KEY=replace-me-with-a-long-random-string
ALLOWED_HOSTS=meili.example.com,www.meili.example.com
CSRF_TRUSTED_ORIGINS=https://meili.example.com,https://www.meili.example.com
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Kampala
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000  # 30d

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=meili_prd01
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://postgres:replace-me@postgres:5432/meili_prd01

# --- RabbitMQ -------------------------------------------------------------
RABBITMQ_USER=meili
RABBITMQ_PASSWORD=replace-me
RABBITMQ_VHOST=meili
CELERY_BROKER_URL=amqp://meili:replace-me@rabbitmq:5672/meili
CELERY_RESULT_BACKEND=django-db

# --- Email (SMTP) ---------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=smtp-user
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@meili.example.com

# --- Notifications --------------------------------------------------------
NOTIFICATION_PROVIDERS={"SMS":"at","WHATSAPP":"at","EMAIL":"smtp"}
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=

# --- Flower ---------------------------------------------------------------
FLOWER_BASIC_AUTH=admin:replace-me

# --- Sentry (optional but strongly recommended) ---------------------------
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Backup / S3 (optional) ----------------------------------------------
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
